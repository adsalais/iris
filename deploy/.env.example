# Copy to deploy/.env and adjust before `docker compose up`.

# ---------------------------------------------------------------------------
# Where data persists. MUST be outside the project tree.
# ---------------------------------------------------------------------------
# All Keycloak (H2 DB, sessions, realm changes) and ClickHouse (data, logs)
# state lives under this directory. `docker compose down -v` does NOT touch it
# because we use bind mounts, not docker-managed volumes.
#
# Default: ~/.iris-data/  (hidden dir in your home; safely outside the project)
# Examples:
#   DATA_DIR=/srv/iris             # system-wide, e.g. on a server
#   DATA_DIR=/mnt/data/iris        # mounted disk
#   DATA_DIR=/Volumes/External/iris # macOS external drive
DATA_DIR=

# ---------------------------------------------------------------------------
# Keycloak admin (the human who manages the realm via the admin console)
# ---------------------------------------------------------------------------
# Used ONLY on first boot to bootstrap the admin user. Changes via the admin
# console afterward go into the data volume; these env vars stop being read.
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# ClickHouse service-admin user (the account iris connects as)
# ---------------------------------------------------------------------------
# This is the XML-defined service identity iris uses for CH. NOT a human user.
# iris's bootstrap creates separate _USER / _GRP roles for human admins.
CLICKHOUSE_USER=iris_admin
CLICKHOUSE_PASSWORD=change-me-please
